# Пример переменных окружения для внешнего деплоя (Coolify/VPS).
# В Lovable файл .env генерируется автоматически — здесь только шаблон
# для документации и сторонних хостингов.

# Бэкенд Lovable Cloud (публичные ключи, безопасны на клиенте)
VITE_SUPABASE_URL=https://ilxgodhosirhhkffqryw.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
VITE_SUPABASE_PROJECT_ID=ilxgodhosirhhkffqryw

# Публичный URL текущей инсталляции. Используется для canonical/og:url
# и для генерации sitemap.xml на этапе сборки.
# Тестовый: https://test.reage.life
# Боевой:   https://reage.life
VITE_APP_URL=https://test.reage.life

# Запретить индексацию (true на тестовом домене, false/убрать на боевом).
# При true PageMeta вставляет <meta name="robots" content="noindex,nofollow">
# и generate-sitemap.ts пишет в robots.txt "Disallow: /".
VITE_NOINDEX=true
